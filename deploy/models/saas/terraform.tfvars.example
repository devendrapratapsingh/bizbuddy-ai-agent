# SaaS Terraform Configuration
# Copy this to terraform.tfvars and fill in the values

aws_region      = "us-east-1"
environment     = "dev"
domain          = "dev.bizbuddy.com"

# VPC Configuration
vpc_cidr              = "10.0.0.0/16"
availability_zones    = ["us-east-1a", "us-east-1b", "us-east-1c"]
private_subnets       = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
public_subnets        = ["10.0.101.0/24", "10.0.102.0/24", "10.0.103.0/24"]

# Kubernetes Configuration
kubernetes_version  = "1.28"
node_instance_type  = "t3.medium"
cluster_min_size    = 2
cluster_max_size    = 5
cluster_desired_size = 2

# Database Configuration
db_username         = "postgres"
db_password         = "CHANGE_THIS_TO_STRONG_PASSWORD"
db_instance_class   = "db.t3.medium"
db_storage_size     = 20
db_multi_az         = false

# Redis Configuration
redis_password      = "CHANGE_THIS_TO_STRONG_PASSWORD"
redis_node_type     = "cache.t3.micro"
redis_num_nodes     = 1
redis_version       = "7.1"

# SSL Certificate
ssl_cert_arn        = ""  # ACM certificate ARN, e.g., arn:aws:acm:region:account:certificate/xxx
create_letsencrypt_cert = false  # Set to true if using cert-manager

# Monitoring
enable_detailed_monitoring = false
log_retention_days         = 30
