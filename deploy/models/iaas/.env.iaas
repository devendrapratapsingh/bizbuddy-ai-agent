# IaaS (Docker Compose) Environment Configuration
# Copy this to .env in the deploy/models/iaas/ directory

# Application
NODE_ENV=production
APP_PORT=3000

# Database
POSTGRES_DB=bizbuddy_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=
REDIS_PORT=6379

# JWT Authentication (generate a strong random secret)
JWT_SECRET=your-super-secret-jwt-key-change-this-minimum-32-chars
SOCKET_IO_SECRET=

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
SOCKET_IO_CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# Database Pool
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE_TIME=10000

# Application Limits
MAX_CONCURRENT_CALLS=10
CONVERSATION_TIMEOUT=3600

# Email (optional)
# EMAIL_FROM=noreply@yourdomain.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-password

# Cloud Storage (optional - configure based on provider)
# CLOUD_PROVIDER=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=bizbuddy-uploads
