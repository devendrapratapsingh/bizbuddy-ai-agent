{
  "env": {
    "ANTHROPIC_BASE_URL": "https://openrouter.ai/api",
    "ANTHROPIC_AUTH_TOKEN": "YOUR_OPENROUTER_TOKEN_HERE",
    "ANTHROPIC_API_KEY": "",
    "ANTHROPIC_MODEL": "stepfun/step-3.5-flash:free",
    "ANTHROPIC_SMALL_FAST_MODEL": "google/gemini-2.0-flash-exp:free"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "WebFetch",
      "WebSearch",
      "Glob",
      "Grep",
      "Agent"
    ],
    "blockedCommands": []
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-github"]
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed"]
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-fetch"]
    }
  }
}
