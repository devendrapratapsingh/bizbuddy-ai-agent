# Claude Code DevOps Skill Project - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================
# AWS Configuration
# ============================================================
export AWS_DEFAULT_REGION=us-east-1
export AWS_PROFILE=default
# export AWS_ACCESS_KEY_ID=your-access-key
# export AWS_SECRET_ACCESS_KEY=your-secret-key

# ============================================================
# Azure Configuration
# ============================================================
# export AZURE_SUBSCRIPTION_ID=your-subscription-id
# export AZURE_TENANT_ID=your-tenant-id
# export AZURE_CLIENT_ID=your-client-id
# export AZURE_CLIENT_SECRET=your-client-secret

# ============================================================
# GCP Configuration
# ============================================================
# export GOOGLE_CLOUD_PROJECT=your-project-id
# export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================================
# Kubernetes Configuration
# ============================================================
# export KUBECONFIG=/Users/uniquenotion/.kube/config
# export KUBE_CONTEXT=your-context-name

# ============================================================
# Terraform Configuration
# ============================================================
# export TF_VAR_environment=dev
# export TF_VAR_region=us-east-1
# export TF_IN_AUTOMATION=true

# ============================================================
# Security & Secrets
# ============================================================
# export VAULT_ADDR=https://vault.example.com
# export VAULT_TOKEN=your-vault-token

# ============================================================
# Monitoring & Observability
# ============================================================
# export PROMETHEUS_URL=http://localhost:9090
# export GRAFANA_URL=http://localhost:3000
# export JAEGER_URL=http://localhost:16686

# ============================================================
# CI/CD Configuration
# ============================================================
# export GITHUB_TOKEN=your-github-token
# export GITLAB_TOKEN=your-gitlab-token
# export JENKINS_URL=http://jenkins.example.com
# export JENKINS_USER=your-username
# export JENKINS_TOKEN=your-api-token

# ============================================================
# Container Registries
# ============================================================
# export DOCKER_REGISTRY=registry.example.com
# export DOCKER_USERNAME=your-username
# export DOCKER_PASSWORD=your-password

# ============================================================
# Claude Code Configuration
# ============================================================
export CLAUDE_CODE_DEBUG=1
export CLAUDE_CODE_MAX_TOKENS=200000
export CLAUDE_CODE_PROJECT_ROOT=/Users/uniquenotion/Private/projects/skill_project

# ============================================================
# Cloud Cost Management (FinOps)
# ============================================================
# export COST_ALLOCATION_TAG=Project
# export COST_CENTER=engineering

# ============================================================
# MLOps Configuration
# ============================================================
# export MLFLOW_TRACKING_URI=http://mlflow.example.com
# export KUBEFLOW_HOST=kubeflow.example.com

# ============================================================
# Development Defaults
# ============================================================
export EDITOR=code
export SHELL=zsh
export LANG=en_US.UTF-8
